<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Faisal Collection – Recipes by KA</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&family=Cormorant+Garamond:ital,wght@0,300;0,600;1,300;1,600&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #fdf8f0;
    --warm-white: #fffdf9;
    --gold: #c8933a;
    --gold-light: #e8b96a;
    --gold-pale: #f5e8c8;
    --rust: #b84a2e;
    --deep: #1a1208;
    --text: #2d1f0e;
    --muted: #7a6448;
    --card-bg: #fffef9;
    --border: rgba(200,147,58,0.2);
    --section-ayam: #fff5e6;
    --section-ikan: #e8f4f0;
    --section-daging: #f5e8e8;
    --section-lain: #ede8f5;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text);
    overflow-x: hidden;
  }

  /* ===== CURSOR ===== */
  body { cursor: none; }
  .cursor {
    width: 12px; height: 12px;
    background: var(--gold);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9999;
    transition: transform 0.15s ease;
    transform: translate(-50%, -50%);
  }
  .cursor-ring {
    width: 36px; height: 36px;
    border: 1.5px solid var(--gold);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9998;
    transition: transform 0.4s ease, width 0.3s, height 0.3s, opacity 0.3s;
    transform: translate(-50%, -50%);
    opacity: 0.6;
  }

  /* ===== NAVBAR ===== */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 3rem;
    height: 72px;
    background: rgba(253,248,240,0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    transition: box-shadow 0.3s;
  }
  nav.scrolled { box-shadow: 0 4px 32px rgba(200,147,58,0.12); }

  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--deep);
    letter-spacing: 0.02em;
  }
  .nav-logo span { color: var(--gold); font-style: italic; }

  .nav-brand {
    display: flex; align-items: center; gap: 12px;
  }
  .chef-avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), var(--rust));
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
    position: relative;
    box-shadow: 0 0 0 3px var(--gold-pale), 0 0 0 5px var(--gold-light);
    animation: pulseRing 3s ease-in-out infinite;
  }
  @keyframes pulseRing {
    0%, 100% { box-shadow: 0 0 0 3px var(--gold-pale), 0 0 0 5px rgba(200,147,58,0.2); }
    50% { box-shadow: 0 0 0 5px var(--gold-pale), 0 0 0 9px rgba(200,147,58,0.1); }
  }
  .brand-text { text-align: right; }
  .brand-name {
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--deep);
    line-height: 1.1;
  }
  .brand-sub {
    font-size: 0.7rem;
    color: var(--gold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex; gap: 2rem; list-style: none;
  }
  .nav-links a {
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    position: relative;
    padding-bottom: 2px;
    transition: color 0.3s;
  }
  .nav-links a::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 100%;
    height: 1.5px;
    background: var(--gold);
    transition: right 0.35s cubic-bezier(0.4,0,0.2,1);
  }
  .nav-links a:hover { color: var(--gold); }
  .nav-links a:hover::after { right: 0; }

  /* ===== HERO ===== */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    padding: 120px 2rem 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 50% 40%, rgba(200,147,58,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 20% 80%, rgba(184,74,46,0.05) 0%, transparent 60%),
      var(--cream);
  }

  .hero-decoration {
    position: absolute; inset: 0; pointer-events: none;
  }
  .hero-line {
    position: absolute;
    border: 1px solid rgba(200,147,58,0.12);
    border-radius: 50%;
    animation: rotateRing linear infinite;
  }
  .hero-line:nth-child(1) { width: 600px; height: 600px; top: 50%; left: 50%; transform: translate(-50%,-50%); animation-duration: 40s; }
  .hero-line:nth-child(2) { width: 800px; height: 800px; top: 50%; left: 50%; transform: translate(-50%,-50%) rotate(30deg); animation-duration: 60s; animation-direction: reverse; }
  .hero-line:nth-child(3) { width: 1000px; height: 1000px; top: 50%; left: 50%; transform: translate(-50%,-50%) rotate(60deg); animation-duration: 80s; }
  @keyframes rotateRing { to { transform: translate(-50%,-50%) rotate(360deg); } }

  .hero-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }
  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 900;
    line-height: 1.05;
    color: var(--deep);
    opacity: 0;
    animation: fadeUp 0.9s 0.4s forwards;
    position: relative; z-index: 1;
  }
  .hero-title em {
    font-style: italic;
    color: var(--gold);
    display: block;
  }
  .hero-sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-style: italic;
    color: var(--muted);
    margin-top: 1.2rem;
    opacity: 0;
    animation: fadeUp 0.9s 0.6s forwards;
  }
  .hero-divider {
    display: flex; align-items: center; gap: 1rem;
    margin: 2rem 0;
    opacity: 0;
    animation: fadeUp 0.9s 0.8s forwards;
  }
  .hero-divider::before, .hero-divider::after {
    content: '';
    flex: 1; max-width: 80px;
    height: 1px;
    background: var(--gold);
    opacity: 0.5;
  }
  .hero-divider span {
    font-size: 1.4rem;
  }
  .hero-stats {
    display: flex; gap: 3rem;
    opacity: 0;
    animation: fadeUp 0.9s 1s forwards;
  }
  .stat { text-align: center; }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--gold);
    display: block;
  }
  .stat-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .scroll-hint {
    position: absolute; bottom: 2.5rem; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    opacity: 0;
    animation: fadeUp 1s 1.4s forwards;
  }
  .scroll-hint span {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .scroll-arrow {
    width: 1px; height: 40px;
    background: var(--gold);
    position: relative;
    overflow: hidden;
  }
  .scroll-arrow::after {
    content: '';
    position: absolute; top: -100%; left: 0;
    width: 100%; height: 100%;
    background: var(--cream);
    animation: scrollDown 1.8s 1.5s ease-in-out infinite;
  }
  @keyframes scrollDown {
    0% { top: -100%; }
    100% { top: 100%; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ===== FILTER TABS ===== */
  .filter-bar {
    position: sticky; top: 72px; z-index: 50;
    background: rgba(253,248,240,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 3rem;
    display: flex; gap: 0; align-items: center;
    overflow-x: auto;
  }
  .filter-tab {
    padding: 1rem 1.5rem;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    border: none;
    background: none;
    cursor: pointer;
    position: relative;
    white-space: nowrap;
    transition: color 0.3s;
  }
  .filter-tab::after {
    content: '';
    position: absolute; bottom: 0; left: 1.5rem; right: 1.5rem;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
  }
  .filter-tab.active { color: var(--gold); }
  .filter-tab.active::after { transform: scaleX(1); }
  .filter-tab:hover { color: var(--deep); }

  /* ===== SECTIONS ===== */
  .section-wrapper { padding: 5rem 3rem; }
  .section-header {
    display: flex; align-items: baseline; gap: 1.5rem;
    margin-bottom: 3rem;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .section-header.visible { opacity: 1; transform: translateY(0); }
  .section-badge {
    font-size: 1.8rem;
    flex-shrink: 0;
  }
  .section-title-group { flex: 1; }
  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 4px;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--deep);
    line-height: 1.1;
  }
  .section-title em { font-style: italic; color: var(--gold); }
  .section-count {
    font-family: 'Playfair Display', serif;
    font-size: 4rem;
    font-weight: 900;
    color: rgba(200,147,58,0.12);
    line-height: 1;
    flex-shrink: 0;
    user-select: none;
  }
  .section-line {
    height: 1px;
    background: linear-gradient(90deg, var(--gold), transparent);
    margin-bottom: 3rem;
    opacity: 0.4;
  }

  /* ===== RECIPE GRID ===== */
  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.8rem;
  }

  /* ===== RECIPE CARD ===== */
  .recipe-card {
    background: var(--card-bg);
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.4s ease;
    cursor: pointer;
    opacity: 0;
    transform: translateY(40px);
    position: relative;
  }
  .recipe-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .recipe-card:hover {
    transform: translateY(-10px) scale(1.01);
    box-shadow: 0 24px 60px rgba(26,18,8,0.15), 0 8px 20px rgba(200,147,58,0.1);
  }
  .recipe-card:hover .card-img img {
    transform: scale(1.08);
  }
  .recipe-card:hover .card-overlay {
    opacity: 1;
  }

  .card-img {
    height: 220px;
    overflow: hidden;
    position: relative;
  }
  .card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4,0,0.2,1);
    display: block;
  }
  .card-img .img-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--gold-pale), #f0e0b8);
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem;
  }
  .card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(26,18,8,0.7) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.4s ease;
    display: flex; align-items: flex-end; padding: 1rem;
  }
  .card-overlay-btn {
    background: var(--gold);
    color: white;
    border: none;
    padding: 0.5rem 1.2rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s;
  }
  .card-overlay-btn:hover { background: var(--rust); }

  .card-tag {
    position: absolute; top: 12px; right: 12px;
    background: rgba(255,253,249,0.95);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 4px 12px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .card-body { padding: 1.2rem 1.4rem 1.4rem; }
  .card-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--deep);
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }
  .card-desc {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .card-footer {
    display: flex; align-items: center; justify-content: space-between;
    border-top: 1px solid var(--border);
    padding-top: 0.9rem;
  }
  .card-by {
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }
  .card-by strong { color: var(--gold); }
  .card-link {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: var(--gold-pale);
    border: 1px solid var(--gold-light);
    display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    font-size: 0.85rem;
    transition: background 0.2s, transform 0.2s;
    color: var(--gold);
  }
  .card-link:hover {
    background: var(--gold);
    color: white;
    transform: rotate(15deg);
  }

  /* ===== SECTION COLORS ===== */
  .sec-ayam { background: linear-gradient(180deg, var(--cream) 0%, #fff8ec 100%); }
  .sec-ikan { background: linear-gradient(180deg, #fff8ec 0%, #eef7f3 100%); }
  .sec-daging { background: linear-gradient(180deg, #eef7f3 0%, #f9eee8 100%); }
  .sec-lain { background: linear-gradient(180deg, #f9eee8 0%, var(--cream) 100%); }

  /* ===== FOOTER ===== */
  footer {
    background: var(--deep);
    color: rgba(255,255,255,0.6);
    text-align: center;
    padding: 3rem;
  }
  footer .f-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }
  footer .f-logo em { font-style: italic; }
  footer p { font-size: 0.8rem; margin-top: 0.5rem; }
  footer a { color: var(--gold-light); text-decoration: none; }

  /* ===== HIDDEN SECTION SUPPORT ===== */
  .section-wrapper.hidden { display: none; }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    nav { padding: 0 1.5rem; }
    .nav-links { display: none; }
    .section-wrapper { padding: 3rem 1.2rem; }
    .filter-bar { padding: 0 1rem; }
    .recipe-grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
    .card-img { height: 160px; }
    .hero-stats { gap: 2rem; }
    .hero-line { display: none; }
  }
  @media (max-width: 480px) {
    .recipe-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
